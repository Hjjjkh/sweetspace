# Worker 环境变量示例
# 复制此文件为 .dev.vars 并填入实际的变量值

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 数据库配置
DATABASE_URL=sqlite:/var/data/app.db

# 文件上传配置 (R2)
R2_BUCKET=love-space-photos
R2_MAX_FILE_SIZE=10485760

# 会话配置
SESSION_SECRET=your_session_secret_here

# 邮件配置 (如果启用邮件通知)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# 应用配置
APP_NAME=Love Space
APP_URL=https://love-space.pages.dev
API_URL=https://sweetspace.248851185.workers.dev
